<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>items</key>
	<array>
		<dict>
            <key>cell</key>
            <string>PSGroupCell</string>
            <key>label</key>
            <string>Light/Dark Mode Editing Selection</string>
            <key>footerText</key>
            <string>Select which mode's colors to edit. Dark and light selections are stored using the same option.</string>
        </dict>
		<dict>
			<key>cell</key>
			<string>PSSegmentCell</string>
			<key>key</key>
			<string>editingDarkMode</string>
			<key>defaults</key>
			<string>com.oakstheawesome.whatamessprefs</string>
			<key>label</key>
			<string>Editing Mode</string>
			<key>validTitles</key>
			<array>
				<string>Light</string>
				<string>Dark</string>
			</array>
			<key>validValues</key>
			<array>
				<false/>
				<true/>
			</array>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>Modern NavBar</string>
			<key>footerText</key>
			<string>This enables a custom, blur-based navigation bar across the entire Messages app. Inspired by Messages in iOS 26.</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSSwitchCell</string>
			<key>default</key>
			<true/>
			<key>label</key>
			<string>Enable Modern NavBar</string>
			<key>lightModeKey</key>
			<string>isModernNavBarEnabled</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>Stock NavBar Settings</string>
			<key>footerText</key>
			<string>Colorizes the stock navigation bar. Only works if Modern NavBar is disabled.</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSSwitchCell</string>
			<key>default</key>
			<false/>
			<key>label</key>
			<string>Enable NavBar Customization</string>
			<key>lightModeKey</key>
			<string>isNavBarCustomizationEnabled</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSButtonCell</string>
			<key>label</key>
			<string>Choose NavBar Tint</string>
			<key>action</key>
			<string>pickNavBarTintColor</string>
		</dict>
	</array>
	<key>title</key>
	<string>NavBar Settings</string>
</dict>
</plist>